# Copy to frontend/.env and fill in real values.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# ---------------------------------------------------------------------------
# Optional: Sentry DSN for frontend error tracking. The ErrorBoundary
# component dynamic-imports @sentry/browser only when this is set, so
# bundles without Sentry don't ship the SDK weight.
# ---------------------------------------------------------------------------
VITE_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Optional: PostHog / Plausible — leave blank until growth-phase
# analytics decision is made.
# ---------------------------------------------------------------------------
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
