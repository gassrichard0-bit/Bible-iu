# Copy to backend/.env and fill in real values. Never commit the
# filled file — the repo's .gitignore already excludes it.
#
# Before starting uvicorn, source it: `set -a && source backend/.env && set +a`
# (or rely on a process manager / Fly secrets in production).

# ---------------------------------------------------------------------------
# Reasoning backend — DeepSeek is wired today. If unset, the
# orchestrator falls back to PlaceholderGenerator (returns stub
# answers; fine for local UI work, useless for real reasoning).
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# ---------------------------------------------------------------------------
# Front-door site password. Empty/unset disables the gate entirely
# (useful for local dev; required in production until per-user auth
# fully replaces it, per CLAUDE.md §4.11).
# ---------------------------------------------------------------------------
BIBLE_IU_PASSWORD=

# ---------------------------------------------------------------------------
# Database — defaults to backend/data/bible-iu.sqlite when unset.
# Switch to a Postgres URL for production-scale (sqlite is fine on
# Fly with a persistent volume up to ~5k users).
# ---------------------------------------------------------------------------
BIBLE_IU_DATABASE_URL=

# ---------------------------------------------------------------------------
# Rate limit knobs — token bucket on /reason endpoint.
# ---------------------------------------------------------------------------
RATE_LIMIT_RPM=6
RATE_LIMIT_BURST=3

# ---------------------------------------------------------------------------
# Optional: Twilio + WebOTP for phone verification (account recovery).
# Off by default; account recovery falls back to backup codes when
# these aren't set.
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
WEBOTP_ORIGIN=

# ---------------------------------------------------------------------------
# Optional: Sentry DSN for backend error tracking. Leave blank to skip.
# ---------------------------------------------------------------------------
SENTRY_DSN=
