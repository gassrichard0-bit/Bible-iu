# ----------------------------------------------------------------------------
# Secrets — NEVER commit. The backend reads these at boot via
# `set -a && source backend/.env && set +a`. They include DEEPSEEK_API_KEY,
# the shared app password, and Twilio creds.
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# ----------------------------------------------------------------------------
# Local SQLite data — user accounts, sessions, bookmarks, annotations,
# notes, room state. Recreatable from seed scripts.
# ----------------------------------------------------------------------------
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
backend/data/bible-iu.sqlite*
backend/data/yjs/
backend/data/uploads/

# ----------------------------------------------------------------------------
# Licensed Bible translations (NKJV, NIV, …) extracted via
# `extract_translation_to_folder.py`. Publishers prohibit
# redistribution, so the JSON dumps stay on disk only — never in git
# even on a private remote. Back up via Time Machine / manual copy.
# ----------------------------------------------------------------------------
backend/data/bibles/

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ----------------------------------------------------------------------------
# Node / Vite / TypeScript build artifacts
# ----------------------------------------------------------------------------
node_modules/
dist/
.vite/
*.tsbuildinfo

# ----------------------------------------------------------------------------
# Editor + OS noise
# ----------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# ----------------------------------------------------------------------------
# Logs, temp files, captures
# ----------------------------------------------------------------------------
*.log
/tmp/
_probe*.mjs
_check*.mjs
